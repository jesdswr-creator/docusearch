{
  "name": "docusearch",
  "version-string": "1.0.0",
  "description": "Offline Intelligent Document Search & OCR System for Windows",
  "dependencies": [
    {
      "name": "sqlite3",
      "features": ["fts5"]
    },
    "zlib",
    {
      "name": "leptonica",
      "features": ["jpeg", "png", "tiff", "openjpeg", "zlib"]
    },
    {
      "name": "tesseract",
      "features": ["jpeg", "png", "tiff"]
    },
    {
      "name": "poppler",
      "features": ["jpeg", "png", "zlib", "openjpeg"]
    }
  ],
  "features": {
    "tests": {
      "description": "Build unit tests (Qt Test framework)"
    }
  }
}
